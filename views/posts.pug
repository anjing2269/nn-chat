doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet",
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css",
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB",
      crossorigin="anonymous")
    link(rel="stylesheet",
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    link(rel="stylesheet", href="style.css")
    title NNチャット
  body.container.overflow-scroll(data-bs-theme=currentTheme)
    nav.navbar.fixed-top.bg-primary
      div.container-fluid
        h1.text-light.navbar-brand.mx-auto NNチャット
          i.bi.bi-chat-dots-fill.ms-1
        div.dropdown
          button.btn.btn-outline-light.dropdown-toggle(type="button" id="menu" data-bs-toggle="dropdown" aria-expanded="false") #{user}
            i.bi.bi-gear-fill.ms-1
          ul.dropdown-menu.dropdown-menu-end(aria-lablledby="menu")
            li
              a.dropdown-item(href="/changeTheme") ライトモード・ダークモードの切り替え
              a.dropdown-item(href="/logout") ログアウト

    each post in posts
      - const borderColor = (user === post.postedBy ? 'border-primary' : '')
      div(class=`card ${borderColor} my-3`)
        div.card-body
          div.d-flex.justify-content-between
            h5.card-title #{post.postedBy}
              if post.postedBy === 'admin'
                i.bi.bi-patch-check-fill.ms-1
            p.card-text
              - const tooltipTitle = `<small>${post.absoluteCreatedAt}</small>`
              small(data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true" title=tooltipTitle) #{post.relativeCreatedAt}
          p.card-text.lead!= post.content
        - const isDeletable = (user === post.postedBy || user === 'admin')
        if isDeletable
          div.card-footer.d-flex.justify-content-end
            form(action="/posts/delete" method="post")
              input(type="hidden", name="id" value=post.id)
              button(type="submit").btn.btn-outline-danger.btn-sm
                i.bi.bi-trash

    div.fixed-bottom.bg-body.p-4
      form(action="/posts", method="post" name="message-form").container-fluid.row.g-3
        div.col-12
          textarea(name="content", cols="40", rows="4" placeholder="Ctrl(Command)+Enterで送信できます").form-control
        div.col-12
          button(type="submit").btn.btn-primary.float-end
            i.bi.bi-send

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js",
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI",
      crossorigin="anonymous")
    script(src="nn-chat.js") 